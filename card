<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>✨ 心願卡片建檔系統 (Google Drive 版)</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen p-4">

    <div class="bg-white p-8 rounded-xl shadow-md max-w-md w-full">
        <h2 class="text-2xl font-bold mb-6 text-gray-800 text-center">✨ 許下心願卡片</h2>
        
        <form id="wishForm" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">我想完成的心願 *</label>
                <input type="text" id="wishTitle" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="例如：去冰島看極光">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">上傳照片到我的雲端硬碟 *</label>
                <input type="file" id="wishImage" accept="image/*" required class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100">
                <img id="imagePreview" class="mt-3 w-full h-40 object-cover rounded-md hidden" alt="預覽圖">
            </div>

            <button type="submit" id="submitBtn" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-md transition duration-200 disabled:bg-gray-400">
                把心願寫進雲端 Excel
            </button>
        </form>
        
        <p id="statusMsg" class="mt-4 text-center text-sm font-semibold hidden"></p>
    </div>

    <script>
        const form = document.getElementById('wishForm');
        const submitBtn = document.getElementById('submitBtn');
        const statusMsg = document.getElementById('statusMsg');
        const wishImage = document.getElementById('wishImage');
        const imagePreview = document.getElementById('imagePreview');

        wishImage.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                imagePreview.src = URL.createObjectURL(file);
                imagePreview.classList.remove('hidden');
            }
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const title = document.getElementById('wishTitle').value;
            const file = wishImage.files[0];

            submitBtn.disabled = true;
            statusMsg.classList.remove('hidden');
            statusMsg.className = "mt-4 text-center text-sm text-amber-600";
            statusMsg.innerText = "⏳ 正在處理照片並同步至 Google 雲端...";

            // 將圖片轉成 Base64 字串，以便透過 JSON 傳送
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = async () => {
                const base64String = reader.result.split(',')[1];

                // 準備打包要傳給 Google 的資料
                const payload = {
                    title: title,
                    image: base64String,
                    contentType: file.type,
                    fileName: file.name
                };

                // 👈 請在這裡替換成你剛剛在 Google Apps Script 部署拿到的「網頁應用程式 URL」
                const GAS_WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbyDBCRgMCFgbGgLhHZJO-QlcnvTsbZJGcW7GXlHhLHGtXs7kK9XWuHgBLS4Z_5I1s2KSA/exec'; 

                try {
                    const response = await fetch(GAS_WEB_APP_URL, {
                        method: 'POST',
                        body: JSON.stringify(payload)
                    });
                    
                    const result = await response.json();
                    
                    if (result.result === 'success') {
                        statusMsg.className = "mt-4 text-center text-sm text-green-600 font-bold";
                        statusMsg.innerText = "🎉 成功！照片已存入雲端硬碟，文字已寫入 Excel！";
                        form.reset();
                        imagePreview.classList.add('hidden');
                    } else {
                        throw new Error(result.error);
                    }
                } catch (error) {
                    statusMsg.className = "mt-4 text-center text-sm text-red-600 font-bold";
                    statusMsg.innerText = "❌ 傳送失敗，請稍後再試。";
                    console.error(error);
                } finally {
                    submitBtn.disabled = false;
                }
            };
        };
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📸心願照片自動建檔系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen p-4">

    <div class="bg-white p-8 rounded-xl shadow-md max-w-md w-full">
        <h2 class="text-2xl font-bold mb-2 text-gray-800 text-center">📸 照片自動建檔</h2>
        <p class="text-sm text-gray-500 text-center mb-6">只需上傳圖片，AI 會自動辨識文字並寫入 Excel</p>
        
        <div class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">上傳心願照片（內含文字） *</label>
                <input type="file" id="wishImage" accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100">
                <img id="imagePreview" class="mt-3 w-full h-40 object-cover rounded-md hidden" alt="預覽圖">
            </div>

            <button type="button" id="submitBtn" onclick="startOCR()" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-md transition duration-200 disabled:bg-gray-400">
                開始 AI 辨識並建檔
            </button>
        </div>
        
        <p id="statusMsg" class="mt-4 text-center text-sm font-semibold hidden"></p>
    </div>

    <script>
        const submitBtn = document.getElementById('submitBtn');
        const statusMsg = document.getElementById('statusMsg');
        const wishImage = document.getElementById('wishImage');
        const imagePreview = document.getElementById('imagePreview');

        // 照片即時預覽功能
        wishImage.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                imagePreview.src = URL.createObjectURL(file);
                imagePreview.classList.remove('hidden');
            }
        });

        // 確保 Base64 檔案讀取完畢的非同步 Promise 包裝
        const fileToBase64 = (file) => new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = (error) => reject(error);
        });

        // 按鈕點擊觸發的核心辨識與傳送函式
        async function startOCR() {
            const file = wishImage.files[0];
            if (!file) {
                alert("❌ 請先選擇一張照片！");
                return;
            }

            // 切換按鈕與文字為載入中狀態
            submitBtn.disabled = true;
            statusMsg.classList.remove('hidden');
            statusMsg.className = "mt-4 text-center text-sm text-amber-600 animate-pulse";
            statusMsg.innerText = "⏳ AI 正在極速讀取照片中的手寫文字...";

            try {
                // 1. 🌟 網頁前端直接調用 AI 引擎提取手寫字 (支援繁體中文 + 英文)
                const ocrResult = await Tesseract.recognize(
                    file,
                    'chi_tra+eng', 
                    { logger: m => { if(m.status === 'recognizing') { statusMsg.innerText = `⏳ AI 辨識中... (${Math.round(m.progress * 100)}%)`; } } }
                );
                
                const detectedText = ocrResult.data.text.trim() || "未能識別出文字";
                statusMsg.innerText = "⏳ 文字辨識成功！正在轉檔照片並準備上傳...";

                // 2. 🌟 確保照片異步轉檔完成，絕不脫軌搶拍
                const base64String = await fileToBase64(file);
                statusMsg.innerText = "⏳ 正在安全傳送至 Excel 資料庫...";

                const payload = {
                    image: base64String,
                    contentType: file.type,
                    fileName: file.name,
                    text: detectedText // 包裹 AI 摳出來的純文字一同傳送
                };

                // 🌟 3. 與後端無污染程式碼對齊的 Google Apps Script 唯一連線點
                const GAS_WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbx5FAznKAq4cGabHJgkEBaMFzC8NN_93-mtSG0ocOqBPnzBJApgwGWTPyy5rwyS6XQaCw/exec'; 

                const response = await fetch(GAS_WEB_APP_URL, {
                    method: 'POST',
                    body: JSON.stringify(payload)
                });
                
                const result = await response.json();
                
                if (result.result === 'success') {
                    statusMsg.className = "mt-4 text-center text-sm text-green-600 font-bold";
                    statusMsg.innerHTML = `🎉 建檔成功！<br><span class="text-xs text-gray-600 font-normal">AI 辨識結果："${result.text}"</span>`;
                    
                    // 清空欄位以利下一次填寫
                    wishImage.value = "";
                    imagePreview.classList.add('hidden');
                } else {
                    throw new Error(result.error);
                }

            } catch (error) {
                alert("❌ 執行失敗：\n" + error.message);
                statusMsg.className = "mt-4 text-center text-sm text-red-600 font-bold";
                statusMsg.innerText = "❌ 資料庫傳送失敗。";
            } finally {
                submitBtn.disabled = false;
            }
        }
    </script>
</body>
</html>
